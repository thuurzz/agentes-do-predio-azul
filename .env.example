# =============================================
# Agentes do Prédio Azul — Environment Config
# =============================================
# Execute scripts/generate-secrets.sh para gerar .env automaticamente.
# Ou copie este arquivo e preencha manualmente:
#   cp .env.example .env

# --- Host/Network ---
NODE_IP=192.168.1.10
KEYCLOAK_URL=http://192.168.1.10:30080

# --- PostgreSQL ---
PG_USER=litellm
PG_PASSWORD=<gerado pelo generate-secrets.sh>
PG_HOST=postgresql.infrastructure.svc.cluster.local
PG_PORT=5432

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<gerado pelo generate-secrets.sh>
KEYCLOAK_REALM=lab-agentes
KEYCLOAK_HOSTNAME_URL=http://192.168.1.10:30080

# --- LiteLLM ---
LITELLM_MASTER_KEY=<gerado pelo generate-secrets.sh>
LITELLM_GENERIC_CLIENT_SECRET=<preenchido pelo 07-configure-sso.sh>

# --- Langfuse ---
LANGFUSE_SALT=<gerado pelo generate-secrets.sh>
LANGFUSE_NEXTAUTH_SECRET=<gerado pelo generate-secrets.sh>
LANGFUSE_CLICKHOUSE_PASSWORD=<gerado pelo generate-secrets.sh>
LANGFUSE_S3_ROOT_PASSWORD=<gerado pelo generate-secrets.sh>
LANGFUSE_KEYCLOAK_CLIENT_SECRET=<preenchido pelo 07-configure-sso.sh>
LANGFUSE_PUBLIC_KEY=<criar API key no Langfuse UI>
LANGFUSE_SECRET_KEY=<criar API key no Langfuse UI>

# --- SSO Test User ---
SSO_TEST_USER=tester
SSO_TEST_PASSWORD=<definir>
